    "policyName": "korean-legal-civil-time",
    "createdFor": "Ultragoal G001",
    "summary": "Korean birth input is a Korean legal civil clock label; longitude only affects true-solar observation correction after legal civil time is resolved.",
    "documentation": "docs/engine/korean-legal-time-policy.md",
