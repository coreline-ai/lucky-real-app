{
  "name": "manseryeok-mcp",
  "version": "0.1.0",
  "private": true,
  "description": "MCP server exposing the manseryeok-engine Korean manseryeok/saju calculation engine (20 tools, resources, prompts).",
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "main": "dist/index.js",
  "scripts": {
    "prebuild": "npm --prefix ../engine run build",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "pretest": "npm run build",
    "test": "vitest run"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "manseryeok-engine": "file:../engine",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.9"
  }
}
