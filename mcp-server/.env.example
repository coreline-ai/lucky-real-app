# manseryeok-mcp HTTP runtime example
# Copy to your process manager or shell environment. Do not commit real secrets.

HOST=127.0.0.1
PORT=3100
CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173

# Optional. If set, POST /mcp requires: Authorization: Bearer <MCP_AUTH_TOKEN>
MCP_AUTH_TOKEN=

# Request hardening
MCP_MAX_BODY_BYTES=1048576
MCP_REQUEST_TIMEOUT_MS=30000
MCP_HEADERS_TIMEOUT_MS=35000

# In-memory single-process rate limit for POST /mcp.
# Multi-instance/Internet-facing deployments should also use reverse-proxy or gateway limits.
MCP_RATE_LIMIT_WINDOW_MS=60000
MCP_RATE_LIMIT_MAX=120

# Dashboard is enabled by default only for local bind hosts.
# For non-local bind (for example HOST=0.0.0.0), expose it only when explicitly intended.
ENABLE_DASHBOARD=false

# production-smoke.mjs options
MCP_SMOKE_BASE_URL=http://127.0.0.1:3100
MCP_SMOKE_AUTH_TOKEN=
MCP_SMOKE_EXPECT_DASHBOARD_DISABLED=false
MCP_SMOKE_MAX_BODY_BYTES=1048576
