{
  "name": "web-lucky",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Seasonal lightweight web demos using manseryeok-engine (Tojeong yearly summary first).",
  "scripts": {
    "data:generate": "npm --prefix ../engine run data-shards:generate -- --output ../web-lucky/public/manseryeok-data",
    "shards": "npm run data:generate",
    "predev": "npm run data:generate",
    "dev": "vite",
    "prebuild": "npm run data:generate",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "browser:check": "node scripts/browser-check.mjs",
    "browser:hub-check": "node scripts/browser-hub-check.mjs",
    "browser:perf": "node scripts/browser-performance-check.mjs",
    "pretest": "npm run data:generate",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "manseryeok-engine": "file:../engine"
  },
  "devDependencies": {
    "playwright": "^1.61.1",
    "typescript": "^5.9.3",
    "vite": "^5.4.10",
    "vitest": "^3.2.4"
  }
}
